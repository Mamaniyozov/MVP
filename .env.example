# Django
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=change-this-to-a-random-secret-key
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,10.0.2.2

# Database
POSTGRES_DB=finance_db
POSTGRES_USER=finance_user
POSTGRES_PASSWORD=finance_pass
# Host'da manage.py ishlatilganda localhost (compose 5432 portni publish qiladi).
# docker-compose.yml backend konteyneriga DB_HOST=db ni o'zi beradi (environment > env_file).
DB_HOST=localhost
DB_PORT=5432

# CORS (Flutter dev uchun)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://10.0.2.2:8000
